// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  products    Product[] // 👈 Relación inversa
}

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  logo        String?   // URL del logo en Cloudinary
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  images      String[]
  categoryId  String   // 👈 Obligatorio
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    Category @relation(fields: [categoryId], references: [id])

  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id])
}


model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  resetToken           String?   @unique
  resetTokenExpires    DateTime?
  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?   // Para el futuro MFA (Google Authenticator)

  audit  AuditLog[]
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?  // Opcional por si quieres registrar quién lo hizo
  userEmail   String?  // Útil para ver rápido quién fue sin hacer joins
  action      String   // "CREATE", "UPDATE", "DELETE"
  entity      String   // "CATEGORY", "PRODUCT", "USER"
  entityId    String?  // ID del objeto afectado
  entityName  String?  // Nombre del objeto (ej: "Ropa Deportiva") para lectura rápida
  details     String?  @db.Text // JSON o texto con los cambios (ej: "Nombre cambiado de A a B")
  ipAddress   String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum Role {
  USER
  ADMIN
}
